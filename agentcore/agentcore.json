        },
        {
          "type": "USER_PREFERENCE",
          "name": "PreferenceLearner",
          "namespaces": [
            "/preferences/{actorId}/"
          ]
        }
      ]
    }
  ],
  "credentials": [],
  "evaluators": [],
  "onlineEvalConfigs": [],
  "agentCoreGateways": [
